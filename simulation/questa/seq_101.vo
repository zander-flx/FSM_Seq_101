tri1 devclrn;
tri1 devpor;
tri1 devoe;
wire \clk_150~input_o ;
wire \in~input_o ;
wire \rst_n~input_o ;
wire \out~output_o ;
wire \clk_led~output_o ;
wire \state[0]~output_o ;
