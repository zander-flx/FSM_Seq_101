input 	clk_150;
input 	rst_n;
input 	in;

// Design Ports Information
// out	=>  Location: PIN_AD14,	 I/O Standard: 2.5 V,	 Current Strength: Default
// clk_led	=>  Location: PIN_K25,	 I/O Standard: 2.5 V,	 Current Strength: Default
// state[0]	=>  Location: PIN_U2,	 I/O Standard: 2.5 V,	 Current Strength: Default
// state[1]	=>  Location: PIN_AF20,	 I/O Standard: 2.5 V,	 Current Strength: Default
// clk_150	=>  Location: PIN_L7,	 I/O Standard: 2.5 V,	 Current Strength: Default
